# Ignore directory - for local files that should not be tracked
.ignore/

# Project config - user-specific (template: config.example.json)
config.json

# Runtime lock file
.run.lock

# Runtime files - user-specific state
data/prd.json
data/prd.archived.json
data/progress.txt
data/progress.archived.txt
data/run-state.json
.last-branch

# Trusted reviewers allowlist - user-specific
scripts/trusted-reviewers.txt

# Claude settings - user-specific (but track project skills)
.claude/settings.local.json

# Backup files
*.backup
*.bak

# Log files
*.log
logs/

# Temporary files
*.tmp
*.swp
*~

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.iml

# direnv
.envrc

__pycache__
